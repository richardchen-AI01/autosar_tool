# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# IDE / editors
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
*.pdb

# PyInstaller
build/
dist/
*.manifest
# spec 文件本身要追（手写的）；spec.bak 不追
*.spec.bak

# Java / Maven / Tycho
target/
*.class
*.jar.sig
.classpath
.project
.settings/
bin/

# Exception: samples/Demo_*/ are template Eclipse projects — .project/.settings
# are part of the spec (Demo gets copied into D:\bswbuilderN\workspace).
!samples/Demo_*/.project
!samples/Demo_*/.settings/
!samples/Demo_*/.settings/**

# Vendored Artop + Sphinx (~66MB) — populated by tools/setup-artop.ps1
# from a local ORIENTAIS_Studio install. Never commit; license + size.
**/local-plugins/

# Eclipse RCP runtime / Equinox cache (运行期产物，禁追)
.metadata/
configuration/org.eclipse.osgi/
configuration/org.eclipse.equinox.app/
configuration/.bak_*/
workspace_test/

# 工程里如果不小心生成了配置文件
*.lock
*.log
*.tmp

# 软链 reference (指向 V25.10 反编结果, 不入库)
# 注意 anchor 到 / 防止把 docs/reference/ 也吞掉
/reference/
# golden 真值例外 (byte-equal 回归基准, sha256 锁版本必须入库)
!/reference/autosar-cfg/
!/reference/autosar-cfg/**
!/reference/ui/
!/reference/ui/**

# 二进制制品
dist/
*.zip
*.tar.gz
*.7z

# 大文件 (避免误提交 V25.10 拷贝)
*.exe
*.pyd
*.dll
*.so
*.dylib

# 屏幕截图（除非主动管）
*.png
*.jpg
!docs/**/*.png
!docs/**/*.jpg

# Claude Code 本地设置（个人覆盖，不入库；项目共享设置走 .claude/settings.json）
.claude/settings.local.json

# MemIf 复刻反编试探 scratch（ADR 0006 后已废弃；保留 ignore 以防有人本机重试）
tools/_decompile/
docs/reference/decompiled-memif/
