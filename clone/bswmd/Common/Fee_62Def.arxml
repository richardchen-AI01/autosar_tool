								<!-- PARAMETER DEFINITION: FeeCancelApi -->
								<ECUC-BOOLEAN-PARAM-DEF UUID="ECUC:edd3a3a9-5b4b-49ca-b335-2eaf6dwe4656">
									<SHORT-NAME>FeeCancelApi</SHORT-NAME>
                                    <ADMIN-DATA>
										<SDGS>
											<SDG GID="iSoft::IdentifiableOptions">
												<SD GID="DERIVED_FLAG">true</SD>
											</SDG>
										</SDGS>
									</ADMIN-DATA>
									<DESC>
										<L-2 L="EN">Whether to enable the job cancellation mechanism.</L-2>
									</DESC>
									<LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
