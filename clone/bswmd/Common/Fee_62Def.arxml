									<SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
								</ECUC-BOOLEAN-PARAM-DEF>
								<!-- PARAMETER DEFINITION: FeeInitErrorNotification -->
								<ECUC-STRING-PARAM-DEF UUID="ECUC:bf0fa4bf-01cb-4d2b-aee6-9361bba43cea">
									<SHORT-NAME>FeeInitErrorNotification</SHORT-NAME>
									<DESC>
										<L-2 L="EN">Fee_62 module initialization failed callback function.</L-2>
									</DESC>
									<LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
									<UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
