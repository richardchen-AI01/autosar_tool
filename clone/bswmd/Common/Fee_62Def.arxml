=								<!-- PARAMETER DEFINITION: FeeImmediateData -->
								<ECUC-BOOLEAN-PARAM-DEF UUID="ECUC:b1116e04-53cd-44a7-8056-f43434aa82c8">
									<SHORT-NAME>FeeImmediateData</SHORT-NAME>
									<DESC>
										<L-2 L="EN">Marker for high priority data.</L-2>
									</DESC>
									<INTRODUCTION>
										<P>
