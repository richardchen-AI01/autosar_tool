{% if NvM.NvMBlockCipheringNumber %}
/**
 * @brief Container for ciphering block
 */
const NvM_BlockCipheringType NvMBlockCiphering[NVM_BLOCK_CIPHERING_NUM_ALL] =
{
    {% for i in range(NvMBlockCiphering|length) %}
    /** {{NvMBlockCiphering[i].shortName_}} */
    {
        {{NvMBlockCiphering[i].NvMNvBlockNVRAMDataLength}}u, /** NvMNvBlockNVRAMDataLength */
        {{NvMBlockCiphering[i].NvMCsmDecryptionJobReference}}u, /** NvMCsmDecryptJobId */
        {{NvMBlockCiphering[i].NvMCsmEncryptionJobReference}}u, /** NvMCsmEncryptJobId */
    },
    {% endfor %}
};
{% endif %}

/**
 * @brief Container for a management structure to configure the composition of a given NVRAM Block Management Type
 */
/* PRQA S 1334 ++ */ /* VL_NvM_1334 */
const NvM_BlockDescriptorType NvM_BlockDescriptor[NVM_BLOCK_NUM_ALL] =
{
{% for i in range(NvMBlockDescriptor|length) %}
{% if i == 0 %}
    /** {{NvMBlockDescriptor[i].shortName_}} */
    {
        {{NvMBlockDescriptor[i].NvMNvramDeviceId}}u,        /** NvMNvramDeviceId */
        NVM_BLOCK_REDUNDANT,    /** NvmBlockManagementType */
{% if NvMCommon.NvMApiConfigClass != 'NVM_API_CONFIG_CLASS_1' and NvMCommon.NvMJobPrioritization == 'STD_ON' %}
        1u,      /** NvmBlockJobPriority */
{% endif %}
        2u,    /** NvmNvBlockNum */
        0u,    /** NvmRomBlockNum */
        {{NvMBlockDescriptor[i].NvMMaxNumOfReadRetries}}u, /** NvMMaxNumOfReadRetries */
        {{NvMBlockDescriptor[i].NvMMaxNumOfWriteRetries}}u,  /** NvMMaxNumOfWriteRetries */
        {{NvMBlockDescriptor[i].NvMBlockCrcType}},        /** NvmBlockCRCType */
        /*
         * Bit 0:NvmWriteBlockOnce
         * Bit 1:NvmBlockWriteProt
         * Bit 2:NvmCalcRamBlockCrc
         * Bit 3:NvmResistantToChangedSw
         * Bit 4:NvmSelectBlockForReadall
         * Bit 5:NvmSelectBlockForWriteall
         * Bit 6:NvMStaticBlockIDCheck
         * Bit 7:NvMWriteVerification
         * Bit 8:NvMBlockUseAutoValidation
         * Bit 9:NvMBlockUseCRCCompMechanism
         * Bit 10:NvMBlockUseSetRamBlockStatus
         * Bit 11:NvMBlockUseSyncMechanism
         * Bit 12:NvMBswMBlockStatusInformation
         * Bit 13:NvMSelectBlockForFirstInitAll
         * BIt 14:NvMBlockUseCompression
         */
        {{NvMBlockDescriptor[i].NvMBlockFlagGroup}}u, /** FlagGroup */
        {{NvMBlockDescriptor[i].NvMNvBlockBaseNumber}}u,   /** NvmNvBlockBaseNumber */
        2u,    /** NvmNvBlockLength */
        {% if NvMBlockDescriptor[i].NvMWriteVerification == 'true' %}
        {{NvMBlockDescriptor[i].NvMWriteVerificationDataSize}}u{% else %}
        0u{% endif %}, /** NvMWriteVerificationDataSize */
        0u, /** RepairIndex */
        {% if NvMCommon.NvMEcucPartitionRef > 1 %}
        {{NvMBlockDescriptor[i].NvMBlockEcucPartitionId}}u, /** NvMBlockEcucPartitionRef */
        {% endif %}
        /* PRQA S 3432, 0306++ */ /* VL_NvM_3432, VL_NvM_0306 */
        {% if NvMBlockDescriptor[i].NvMBlockUseCrc == 'STD_ON' %}
        NvMCrcBuf_{{NvMBlockDescriptor[i].shortName_}}{% else %}
        NULL_PTR{% endif %},    /** NvmBlockCrcBuffAddress */
        (uint8*) {{NvMBlockDescriptor[i].NvMRamBlockDataAddress}},	/** NvMRamBlockDataAddress */
        NULL_PTR,   /** NvMRomBlockDataAddress */
        /* PRQA S 3432, 0306 -- */
        NULL_PTR,   /** NvMInitBlockCallback */
        NULL_PTR,   /** NvMSingleBlockCallback */
        NULL_PTR,   /** NvM_ReadRamBlockFromNvmCallbackType */
        NULL_PTR,   /** NvM_WriteRamBlockToNvmCallbackType */
        {% if NvM.NvMBlockCipheringEabled == 'STD_ON' %}
        {{NvMBlockDescriptor[i].NvMBlockCipheringRef}}, /** NvMBlockCipheringRef */
        {% endif %}
    },
{% else %}
    /** {{NvMBlockDescriptor[i].shortName_}} */
    {
        {{NvMBlockDescriptor[i].NvMNvramDeviceId}}u,	        /** NvMNvramDeviceId */
        {{NvMBlockDescriptor[i].NvMBlockManagementType}},    /** NvmBlockManagementType */
{% if NvMCommon.NvMApiConfigClass != 'NVM_API_CONFIG_CLASS_1' and NvMCommon.NvMJobPrioritization == 'STD_ON' %}
        {{NvMBlockDescriptor[i].NvMBlockJobPriority}}u,    /** NvmBlockJobPriority */
{% endif %}
        {{NvMBlockDescriptor[i].NvMNvBlockNum}}u,    /** NvmNvBlockNum */
        {{NvMBlockDescriptor[i].NvMRomBlockNum}}u,    /** NvmRomBlockNum */
        {{NvMBlockDescriptor[i].NvMMaxNumOfReadRetries}}u, /** NvMMaxNumOfReadRetries */
        {{NvMBlockDescriptor[i].NvMMaxNumOfWriteRetries}}u,  /** NvMMaxNumOfWriteRetries */
        {% if NvMBlockDescriptor[i].NvMBlockUseCrc == 'STD_ON' %}
        {{NvMBlockDescriptor[i].NvMBlockCrcType}}{% else %}
        NVM_CRC_NOT_USED{% endif %},        /** NvmBlockCRCType */
        /*
         * Bit 0:NvmWriteBlockOnce
         * Bit 1:NvmBlockWriteProt
         * Bit 2:NvmCalcRamBlockCrc
         * Bit 3:NvmResistantToChangedSw
         * Bit 4:NvmSelectBlockForReadall
         * Bit 5:NvmSelectBlockForWriteall
         * Bit 6:NvMStaticBlockIDCheck
         * Bit 7:NvMWriteVerification
         * Bit 8:NvMBlockUseAutoValidation
         * Bit 9:NvMBlockUseCRCCompMechanism
         * Bit 10:NvMBlockUseSetRamBlockStatus
         * Bit 11:NvMBlockUseSyncMechanism
         * Bit 12:NvMBswMBlockStatusInformation
         * Bit 13:NvMSelectBlockForFirstInitAll
         * BIt 14:NvMBlockUseCompression
         */
        {{NvMBlockDescriptor[i].NvMBlockFlagGroup}}u, /** FlagGroup */
        {{NvMBlockDescriptor[i].NvMNvBlockBaseNumber}}u,    /** NvmNvBlockBaseNumber */
        {{NvMBlockDescriptor[i].NvMNvBlockLength}}u,    /** NvmNvBlockLength */
        {% if NvMBlockDescriptor[i].NvMWriteVerification == 'true' %}
        {{NvMBlockDescriptor[i].NvMWriteVerificationDataSize}}u{% else %}
        0u{% endif %}, /** NvMWriteVerificationDataSize */
        0u, /** RepairIndex */
        {% if NvMCommon.NvMEcucPartitionRef > 1 %}
        {{NvMBlockDescriptor[i].NvMBlockEcucPartitionId}}u, /** NvMBlockEcucPartitionRef */
        {% endif %}
        /* PRQA S 3432, 0306++ */ /* VL_NvM_3432, VL_NvM_0306 */
        {% if NvMBlockDescriptor[i].NvMBlockUseCrc == 'STD_ON' %}
        NvMCrcBuf_{{NvMBlockDescriptor[i].shortName_}}{% else %}
        NULL_PTR{% endif %},    /** NvmBlockCrcBuffAddress */
        {% if NvMBlockDescriptor[i].NvMRamBlockDataAddress %}
        (uint8*) {{NvMBlockDescriptor[i].NvMRamBlockDataAddress}}{% else %}
        NULL_PTR{% endif %},    /** NvMRamBlockDataAddress */
        {% if NvMBlockDescriptor[i].NvMRomBlockDataAddress %}
        (uint8*) {{NvMBlockDescriptor[i].NvMRomBlockDataAddress}}{% else %}
        NULL_PTR{% endif %},       /** NvMRomBlockDataAddress */
        /* PRQA S 3432, 0306 -- */
        {% if NvMBlockDescriptor[i].NvMInitBlockCallbackFnc %}
        {{NvMBlockDescriptor[i].NvMInitBlockCallbackFnc}}{% elif NvMBlockDescriptor[i].NvMBlockUsePort == 'STD_ON' and NvMBlockDescriptor[i].NvMInitBlockCallback and NvMBlockDescriptor[i].NvMInitBlockCallbackFnc is none %}
        Rte_Call_PNIB_{{NvMBlockDescriptor[i].shortName_}}_InitBlock{% else %}
        NULL_PTR{% endif %},       /** NvMInitBlockCallback */
        {% if NvMBlockDescriptor[i].NvMSingleBlockCallbackFnc %}
        {{NvMBlockDescriptor[i].NvMSingleBlockCallbackFnc}}{% elif NvMBlockDescriptor[i].NvMBlockUsePort == 'STD_ON' and NvMBlockDescriptor[i].NvMSingleBlockCallback and NvMBlockDescriptor[i].NvMSingleBlockCallbackFnc is none %}
        Rte_Call_PNJF_{{NvMBlockDescriptor[i].shortName_}}_JobFinished{% else %}
        NULL_PTR{% endif %},    /** NvmSingleBlockCallback */
        {% if NvMBlockDescriptor[i].NvMBlockUseSyncMechanism == 'STD_ON' %}
        {{NvMBlockDescriptor[i].NvMReadRamBlockFromNvCallback}}{% else %}
        NULL_PTR{% endif %},       /** NvM_ReadRamBlockFromNvmCallbackType */
        {% if NvMBlockDescriptor[i].NvMBlockUseSyncMechanism == 'STD_ON' %}
        {{NvMBlockDescriptor[i].NvMWriteRamBlockToNvCallback}}{% else %}
        NULL_PTR{% endif %},       /** NvM_WriteRamBlockToNvmCallbackType */
        {% if NvM.NvMBlockCipheringEabled == 'STD_ON' %}
        {{NvMBlockDescriptor[i].NvMBlockCipheringRef}}, /** NvMBlockCipheringRef */
        {% endif %}
    },
{% endif %}
{% endfor %}
};
/* PRQA S 1334 -- */
#define NVM_STOP_SEC_CONFIG_DATA_UNSPECIFIED
#include "NvM_MemMap.h"

{% if NvMCommon.NvMApiConfigClass != 'NVM_API_CONFIG_CLASS_1' and NvMCommon.NvMJobPrioritization == 'STD_ON' %}
