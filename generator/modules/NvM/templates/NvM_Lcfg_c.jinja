uint16 NvM_PriorityTable[2][NVM_TABLE_SIZE_PRIORITY] =
/* PRQA S 3408,3132 -- */
{
    { {% for i in range(NvM.NVM_TABLE_SIZE_PRIORITY) %}0x0000U, {% endfor %} },
    { {% for i in range(NvM.NVM_TABLE_SIZE_PRIORITY) %}0x0000U, {% endfor %} }
};
#define NVM_STOP_SEC_VAR_INIT_16
#include "NvM_MemMap.h"
{% endif %}

