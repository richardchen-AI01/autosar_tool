{% if NvMBlockDescriptor[i].NvMBlockUseCrc == 'STD_ON' %}
{% if NvMBlockDescriptor[i].NvMBlockManagementType == 'NVM_BLOCK_REDUNDANT' or NvMBlockDescriptor[i].NvMBlockManagementType == 'NVM_BLOCK_NATIVE' %}
uint32 NvMCrcBuf_{{NvMBlockDescriptor[i].shortName_}}[1];
{% else %}
uint32 NvMCrcBuf_{{NvMBlockDescriptor[i].shortName_}}[{{NvMBlockDescriptor[i].NvMDataSetTypeNvNum}}];
