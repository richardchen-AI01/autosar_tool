<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

    <!-- Views — Validation/Detail/AUTOSAR Explorer.
         AUTOSAR Explorer = thin CommonNavigator subclass, AR-tree rendering
         via Sphinx open-source content provider (declared below). -->
    <extension
            point="org.eclipse.ui.views">
        <category
                id="cn.com.myorg.bswbuilder.ui.viewCategory"
                name="BSW Builder"/>

        <view
                category="cn.com.myorg.bswbuilder.ui.viewCategory"
                class="cn.com.myorg.bswbuilder.ui.views.BswExplorerView"
                id="cn.com.myorg.bswbuilder.ui.bswExplorer"
                name="AUTOSAR Explorer"
                restorable="true"/>

        <view
                category="cn.com.myorg.bswbuilder.ui.viewCategory"
                class="cn.com.myorg.bswbuilder.ui.views.ValidationView"
                id="cn.com.myorg.bswbuilder.ui.views.Validation"
                name="Autosar Validation"
                restorable="true"/>

        <view
                category="cn.com.myorg.bswbuilder.ui.viewCategory"
                class="cn.com.myorg.bswbuilder.ui.views.DetailView"
                id="cn.com.myorg.bswbuilder.ui.views.Detail"
                name="Detail"
                restorable="true"/>
    </extension>

    <!-- Navigator content for AR-tree drilling. Sphinx
         BasicExplorerContentProvider / BasicExplorerLabelProvider are
         open-source Eclipse-licensed classes from
         org.eclipse.sphinx.emf.explorer; we just reference them by FQN. -->
    <extension
            point="org.eclipse.ui.navigator.navigatorContent">
        <navigatorContent
                contentProvider="org.eclipse.sphinx.emf.explorer.BasicExplorerContentProvider"
                id="cn.com.myorg.bswbuilder.ui.arxmlContent"
                labelProvider="org.eclipse.sphinx.emf.explorer.BasicExplorerLabelProvider"
                name="AUTOSAR Model"
                priority="high">
            <triggerPoints>
                <or>
                    <instanceof value="org.eclipse.core.resources.IFile"/>
                    <instanceof value="org.eclipse.emf.ecore.EObject"/>
                </or>
            </triggerPoints>
            <possibleChildren>
                <instanceof value="org.eclipse.emf.ecore.EObject"/>
            </possibleChildren>
        </navigatorContent>
    </extension>

    <!-- Wire BswExplorerView to Eclipse standard resource content (project
         tree) + our arxmlContent (AR-tree drill into .arxml). -->
    <extension
            point="org.eclipse.ui.navigator.viewer">
        <viewer viewerId="cn.com.myorg.bswbuilder.ui.bswExplorer"/>
        <viewerContentBinding viewerId="cn.com.myorg.bswbuilder.ui.bswExplorer">
            <includes>
                <contentExtension pattern="org.eclipse.ui.navigator.resourceContent"/>
                <contentExtension pattern="org.eclipse.ui.navigator.resources.filters.*"/>
                <contentExtension pattern="cn.com.myorg.bswbuilder.ui.arxmlContent"/>
            </includes>
        </viewerContentBinding>
        <viewerActionBinding viewerId="cn.com.myorg.bswbuilder.ui.bswExplorer">
            <includes>
                <actionExtension pattern="org.eclipse.ui.navigator.resources.*"/>
            </includes>
        </viewerActionBinding>
    </extension>

    <!-- Editors — Generic Module Manager (E5-4).
         跟参考 V25.10 NewBswBuilderEditor 同 pattern: 一个通用 editor 服务
         所有 BSW 模块的 .arxml, schema 走 BswSchemaLoader, addPages 按
         GModuleDef.gGetContainers() 单实例 → GenericGeneralFormPage,
         多实例 → GenericMasterDetailFormPage 派发, 0 行 per-module UI 代码。

         旧 MemIfModuleManagerEditor 暂保留作 v0.3 fallback (id 不同,
         default=false 让 GenericModuleEditor 接管 .arxml)。 -->
    <extension
            point="org.eclipse.ui.editors">
        <editor
                id="cn.com.myorg.bswbuilder.ui.editors.GenericModuleEditor"
                name="BSW Module Manager"
                extensions="arxml"
                class="cn.com.myorg.bswbuilder.ui.editors.GenericModuleEditor"
                default="true"
                contributorClass="org.eclipse.sphinx.emf.editors.forms.BasicTransactionalEditorActionBarContributor"/>

        <!-- legacy MemIf-only editor — keep registered for "Open With" 菜单, 不
             default; 等 v0.3 verify generic editor 4 模块全跑通后删。 -->
        <editor
                id="cn.com.myorg.bswbuilder.ui.editors.MemIfModuleManagerEditor"
                name="MemIf Module Manager (legacy)"
                extensions="arxml"
                class="cn.com.myorg.bswbuilder.ui.editors.MemIfModuleManagerEditor"
                contributorClass="org.eclipse.ui.part.EditorActionBarContributor"/>

        <!-- v0.2 起 CDT feature 接管 .c/.h 编辑器 (语法高亮 + folding +
             outline + include 跳转)。我们之前注册的 plain TextEditor
             已删 — CDT 注册的 C/C++ Editor 优先级更高，自动作为 default。 -->
    </extension>

    <!-- Commands — Validate / Generate / 其它 stub。从 Project Explorer
         右键菜单触发。 -->
    <extension
            point="org.eclipse.ui.commands">
        <category
                id="cn.com.myorg.bswbuilder.commands.category"
                name="BSW Builder"/>
        <command
                categoryId="cn.com.myorg.bswbuilder.commands.category"
                defaultHandler="cn.com.myorg.bswbuilder.ui.handlers.GenerateMemIfHandler"
                id="cn.com.myorg.bswbuilder.commands.generateMemIf"
                name="Generate"/>
        <command
                categoryId="cn.com.myorg.bswbuilder.commands.category"
                defaultHandler="cn.com.myorg.bswbuilder.ui.handlers.ValidateMemIfHandler"
                id="cn.com.myorg.bswbuilder.commands.validateMemIf"
                name="Validate"/>
        <command
                categoryId="cn.com.myorg.bswbuilder.commands.category"
                defaultHandler="cn.com.myorg.bswbuilder.ui.handlers.SynchronizeModuleStubHandler"
                id="cn.com.myorg.bswbuilder.commands.synchronizeModule"
                name="Synchronize Module"/>
        <command
                categoryId="cn.com.myorg.bswbuilder.commands.category"
                defaultHandler="cn.com.myorg.bswbuilder.ui.handlers.UpdateBswmdStubHandler"
                id="cn.com.myorg.bswbuilder.commands.updateBswmd"
                name="Update Bswmd"/>
        <command
                categoryId="cn.com.myorg.bswbuilder.commands.category"
                defaultHandler="cn.com.myorg.bswbuilder.ui.handlers.DeleteModuleStubHandler"
                id="cn.com.myorg.bswbuilder.commands.deleteModule"
                name="Delete"/>
    </extension>

    <!-- 右键菜单 — 挂到 Eclipse Project Explorer 的 popup 上。
         visibleWhen 限定: 选中的是 IFile + 扩展名 .arxml + 路径含
         /BSW_Builder/ (即 BSW 模块配置文件，不是 bswmds/ 下的描述文件)。
         5 项扁平结构跟参考 V25.10 一致 (用户 2026-04-29 验证):
            Synchronize Module / Validate / Generate / Update Bswmd / Delete -->
    <!-- 顶层菜单 "BSW Configurator" — 直接放 Show AUTOSAR Explorer / Project Explorer
         入口, 不用钻 Window→Show View→Other。配 importWizards 类占位 category
         (跟参考 V25.10 cn.com.isoft.importWizards 同款分类容器). -->
    <extension point="org.eclipse.ui.menus">
        <menuContribution
                locationURI="menu:org.eclipse.ui.main.menu?after=window">
            <menu
                    id="cn.com.myorg.bswbuilder.ui.menu.bsw"
                    label="BSW Configurator">
                <command
                        commandId="org.eclipse.ui.views.showView"
                        label="AUTOSAR Explorer"
                        style="push">
                    <parameter
                            name="org.eclipse.ui.views.showView.viewId"
                            value="cn.com.myorg.bswbuilder.ui.bswExplorer"/>
                </command>
                <command
                        commandId="org.eclipse.ui.views.showView"
                        label="Project Explorer"
                        style="push">
                    <parameter
                            name="org.eclipse.ui.views.showView.viewId"
                            value="org.eclipse.ui.navigator.ProjectExplorer"/>
                </command>
                <separator name="autosar.views"/>
                <command
                        commandId="org.eclipse.ui.views.showView"
                        label="Autosar Validation"
                        style="push">
                    <parameter
                            name="org.eclipse.ui.views.showView.viewId"
                            value="cn.com.myorg.bswbuilder.ui.views.Validation"/>
                </command>
                <command
                        commandId="org.eclipse.ui.views.showView"
                        label="Detail"
                        style="push">
                    <parameter
                            name="org.eclipse.ui.views.showView.viewId"
                            value="cn.com.myorg.bswbuilder.ui.views.Detail"/>
                </command>
            </menu>
        </menuContribution>
    </extension>

    <!-- importWizards: "BSW Configurator" category + 1 个具体 wizard。
         空 category Eclipse 会从 File→Import 对话框过滤掉, 必须至少 1 个
         wizard 才显示。BswProjectImportWizard 复用 Eclipse 标准的
         WizardProjectsImportPage (= "Existing Projects into Workspace"
         的页面), Finish 时同步切到 BSW Configurator perspective —
         AUTOSAR Explorer 会跟着出现。 -->
    <extension point="org.eclipse.ui.importWizards">
        <category
                id="cn.com.myorg.bswbuilder.ui.importCategory"
                name="BSW Configurator"/>
        <wizard
                category="cn.com.myorg.bswbuilder.ui.importCategory"
                class="cn.com.myorg.bswbuilder.ui.wizards.BswProjectImportWizard"
                id="cn.com.myorg.bswbuilder.ui.importWizard.bswProject"
                name="Existing BSW Project">
            <description>
                Import an existing BSW project from a workspace directory and
                switch to the BSW Configurator perspective.
            </description>
        </wizard>
    </extension>

    <extension
            point="org.eclipse.ui.menus">
        <menuContribution
                locationURI="popup:org.eclipse.ui.popup.any?after=additions">
            <command
                    commandId="cn.com.myorg.bswbuilder.commands.synchronizeModule"
                    label="Synchronize Module"
                    style="push">
                <visibleWhen checkEnabled="false">
                    <iterate ifEmpty="false">
                        <or>
                            <instanceof value="cn.com.myorg.mal.model.ModuleModel"/>
                            <adapt type="org.eclipse.core.resources.IFile">
                                <test
                                        property="org.eclipse.core.resources.name"
                                        value="*.arxml"/>
                                <test
                                        property="org.eclipse.core.resources.path"
                                        value="*/BSW_Builder/*"/>
                            </adapt>
                        </or>
                    </iterate>
                </visibleWhen>
            </command>
            <command
                    commandId="cn.com.myorg.bswbuilder.commands.validateMemIf"
                    label="Validate"
                    style="push">
                <visibleWhen checkEnabled="false">
                    <iterate ifEmpty="false">
                        <or>
                            <instanceof value="cn.com.myorg.mal.model.ModuleModel"/>
                            <adapt type="org.eclipse.core.resources.IFile">
                                <test
                                        property="org.eclipse.core.resources.name"
                                        value="*.arxml"/>
                                <test
                                        property="org.eclipse.core.resources.path"
                                        value="*/BSW_Builder/*"/>
                            </adapt>
                        </or>
                    </iterate>
                </visibleWhen>
            </command>
            <command
                    commandId="cn.com.myorg.bswbuilder.commands.generateMemIf"
                    label="Generate"
                    style="push">
                <visibleWhen checkEnabled="false">
                    <iterate ifEmpty="false">
                        <or>
                            <instanceof value="cn.com.myorg.mal.model.ModuleModel"/>
                            <adapt type="org.eclipse.core.resources.IFile">
                                <test
                                        property="org.eclipse.core.resources.name"
                                        value="*.arxml"/>
                                <test
                                        property="org.eclipse.core.resources.path"
                                        value="*/BSW_Builder/*"/>
                            </adapt>
                        </or>
                    </iterate>
                </visibleWhen>
            </command>
            <command
                    commandId="cn.com.myorg.bswbuilder.commands.updateBswmd"
                    label="Update Bswmd"
                    style="push">
                <visibleWhen checkEnabled="false">
                    <iterate ifEmpty="false">
                        <or>
                            <instanceof value="cn.com.myorg.mal.model.ModuleModel"/>
                            <adapt type="org.eclipse.core.resources.IFile">
                                <test
                                        property="org.eclipse.core.resources.name"
                                        value="*.arxml"/>
                                <test
                                        property="org.eclipse.core.resources.path"
                                        value="*/BSW_Builder/*"/>
                            </adapt>
                        </or>
                    </iterate>
                </visibleWhen>
            </command>
            <command
                    commandId="cn.com.myorg.bswbuilder.commands.deleteModule"
                    label="Delete"
                    style="push">
                <visibleWhen checkEnabled="false">
                    <iterate ifEmpty="false">
                        <or>
                            <instanceof value="cn.com.myorg.mal.model.ModuleModel"/>
                            <adapt type="org.eclipse.core.resources.IFile">
                                <test
                                        property="org.eclipse.core.resources.name"
                                        value="*.arxml"/>
                                <test
                                        property="org.eclipse.core.resources.path"
                                        value="*/BSW_Builder/*"/>
                            </adapt>
                        </or>
                    </iterate>
                </visibleWhen>
            </command>
        </menuContribution>
    </extension>

    <!-- AUTOSAR Explorer view — 自定义 CommonNavigator 子类。
         参考: cn.com.isoft.pal.ui.explorer.AutosarNavigator
              (view id cn.com.isoft.pal.views.autosarexplorer)。 -->
    <extension point="org.eclipse.ui.views">
        <category
                id="cn.com.myorg.bswbuilder.ui.viewCategory"
                name="BSW Builder"/>
        <view
                allowMultiple="false"
                category="cn.com.myorg.bswbuilder.ui.viewCategory"
                class="cn.com.myorg.bswbuilder.ui.navigator.BswAutosarExplorerView"
                id="cn.com.myorg.bswbuilder.ui.bswExplorer"
                name="AUTOSAR Explorer"
                restorable="true"/>
    </extension>

    <!-- navigatorContent — label/icon overlay 而已 (跟 Project Explorer 一致全显示)。
         2026-05-01: children 全交给 Eclipse 标准 resourceContent 走文件系统;
         我们这条只给 BSW_Builder/<MCU>/<Module>.arxml 去后缀 + 模块图标
         (priority="higher" 压过 resourceContent 的标签)。 -->
    <extension point="org.eclipse.ui.navigator.navigatorContent">
        <navigatorContent
                contentProvider="cn.com.myorg.bswbuilder.ui.navigator.BswExplorerContentProvider"
                labelProvider="cn.com.myorg.bswbuilder.ui.navigator.BswExplorerLabelProvider"
                id="cn.com.myorg.bswbuilder.ui.bswNavigatorContent"
                name="BSW Builder"
                priority="highest"
                activeByDefault="true">
            <triggerPoints>
                <or>
                    <instanceof value="org.eclipse.core.resources.IFile"/>
                    <instanceof value="org.eclipse.core.resources.IFolder"/>
                    <instanceof value="org.eclipse.core.resources.IProject"/>
                </or>
            </triggerPoints>
            <!-- possibleChildren 是 CommonNavigator 框架决定 labelProvider/getImage
                 是否被调用 的关键 — 不是 triggerPoints。triggerPoints 只决定
                 contentProvider.getChildren 的回调。少了 possibleChildren →
                 IFile/IFolder/IProject 的 label 落到 resourceContent 标准 provider,
                 .arxml 后缀 + 图标 polish 全丢。bswbuilder26 里这条遗漏过, 是
                 "S32K148 下模块名又带 .arxml" regression 的根因。 -->
            <possibleChildren>
                <or>
                    <instanceof value="org.eclipse.core.resources.IFile"/>
                    <instanceof value="org.eclipse.core.resources.IFolder"/>
                    <instanceof value="org.eclipse.core.resources.IProject"/>
                </or>
            </possibleChildren>
        </navigatorContent>
    </extension>

    <extension point="org.eclipse.ui.navigator.viewer">
        <viewer viewerId="cn.com.myorg.bswbuilder.ui.bswExplorer"/>
        <!-- viewerContentBinding: 把 Eclipse 标准 resourceContent 当 root
             (跟参考 V25.10 cn.com.isoft.pal.views.autosarexplorer 一样)。
             这是双击 .arxml 能打开 editor 的关键 — Eclipse 的 default
             open action 走的是 resourceContent 这条路径。我们的
             bswNavigatorContent 走 priority="high" 接管 label/icon。 -->
        <viewerContentBinding viewerId="cn.com.myorg.bswbuilder.ui.bswExplorer">
            <includes>
                <contentExtension isRoot="true" pattern="org.eclipse.ui.navigator.resourceContent"/>
                <contentExtension pattern="cn.com.myorg.bswbuilder.ui.bswNavigatorContent"/>
                <contentExtension pattern="org.eclipse.ui.navigator.resources.filters.*"/>
                <contentExtension pattern="org.eclipse.ui.navigator.resources.linkHelper"/>
            </includes>
        </viewerContentBinding>
        <!-- viewerActionBinding: 绑标准 resource actions (Open / Open With /
             Refresh / Edit / Refactor)。没这个 → 双击没反应 + 右键菜单
             只有我们自己的 5 项。参考 V25.10 同款绑定。 -->
        <viewerActionBinding viewerId="cn.com.myorg.bswbuilder.ui.bswExplorer">
            <includes>
                <actionExtension pattern="org.eclipse.ui.navigator.resources.*"/>
                <actionExtension pattern="org.eclipse.ui.navigator.resources.actions.EditActions"/>
                <actionExtension pattern="org.eclipse.ui.navigator.resources.actions.RefactorActions"/>
            </includes>
        </viewerActionBinding>
    </extension>

</plugin>
