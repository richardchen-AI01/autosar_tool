<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

    <!-- Views — match the reference V25.10 perspective:
           Autosar Explorer (left, project tree)
           Property Form (right, ECUC parameter editor — will become an
                          EditorPart "MemIf Module Manager" in U2)
           Validation (bottom-left, table)
         The old "Configuration Editors" flat-label view is removed in U1
         in favor of Autosar Explorer; clear UI break, no point keeping
         both. -->
    <extension
            point="org.eclipse.ui.views">
        <category
                id="cn.com.myorg.bswbuilder.ui.viewCategory"
                name="BSW Builder"/>

        <view
                category="cn.com.myorg.bswbuilder.ui.viewCategory"
                class="cn.com.myorg.bswbuilder.ui.views.AutosarExplorerView"
                id="cn.com.myorg.bswbuilder.ui.views.AutosarExplorer"
                name="Autosar Explorer"
                restorable="true"/>

        <view
                category="cn.com.myorg.bswbuilder.ui.viewCategory"
                class="cn.com.myorg.bswbuilder.ui.views.PropertyFormView"
                id="cn.com.myorg.bswbuilder.ui.views.PropertyForm"
                name="Properties"
                restorable="true"/>

        <view
                category="cn.com.myorg.bswbuilder.ui.viewCategory"
                class="cn.com.myorg.bswbuilder.ui.views.ValidationView"
                id="cn.com.myorg.bswbuilder.ui.views.Validation"
                name="Validation"
                restorable="true"/>
    </extension>

    <!-- Commands: Generate / Validate. Still registered so the BSW menu
         and the right-click context menu can both invoke them. The old
         toolbar contributions are gone — user feedback #2: actions live
         on the right-click menu of the module ARXML node, mirroring the
         reference V25.10. -->
    <extension
            point="org.eclipse.ui.commands">
        <category
                id="cn.com.myorg.bswbuilder.commands.category"
                name="BSW Builder"/>
        <command
                categoryId="cn.com.myorg.bswbuilder.commands.category"
                defaultHandler="cn.com.myorg.bswbuilder.ui.handlers.GenerateMemIfHandler"
                id="cn.com.myorg.bswbuilder.commands.generateMemIf"
                name="Generate MemIf"/>
        <command
                categoryId="cn.com.myorg.bswbuilder.commands.category"
                defaultHandler="cn.com.myorg.bswbuilder.ui.handlers.ValidateMemIfHandler"
                id="cn.com.myorg.bswbuilder.commands.validateMemIf"
                name="Validate MemIf"/>
    </extension>

    <!-- BSW menu (top-bar) entries. Tree-node right-click menu is built
         programmatically in AutosarExplorerView.fillContextMenu(). -->
    <extension
            point="org.eclipse.ui.menus">
        <menuContribution
                locationURI="menu:cn.com.myorg.bswbuilder.menu?after=generators">
            <command
                    commandId="cn.com.myorg.bswbuilder.commands.generateMemIf"
                    label="Generate MemIf"
                    style="push"/>
        </menuContribution>
        <menuContribution
                locationURI="menu:cn.com.myorg.bswbuilder.menu?after=validators">
            <command
                    commandId="cn.com.myorg.bswbuilder.commands.validateMemIf"
                    label="Validate MemIf"
                    style="push"/>
        </menuContribution>
    </extension>

</plugin>
