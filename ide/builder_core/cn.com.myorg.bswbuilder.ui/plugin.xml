<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

    <!-- Views — IDE pivot phase 2 (2026-04-30):
         AutosarExplorer → 删 (用 Eclipse 标准 Project Explorer 替代)
         PropertyForm    → 删 (legacy ViewPart, FormEditor 接管)
         Validation/Detail 保留 (BSW Builder 自有视图) -->
    <extension
            point="org.eclipse.ui.views">
        <category
                id="cn.com.myorg.bswbuilder.ui.viewCategory"
                name="BSW Builder"/>

        <view
                category="cn.com.myorg.bswbuilder.ui.viewCategory"
                class="cn.com.myorg.bswbuilder.ui.views.ValidationView"
                id="cn.com.myorg.bswbuilder.ui.views.Validation"
                name="Autosar Validation"
                restorable="true"/>

        <view
                category="cn.com.myorg.bswbuilder.ui.viewCategory"
                class="cn.com.myorg.bswbuilder.ui.views.DetailView"
                id="cn.com.myorg.bswbuilder.ui.views.Detail"
                name="Detail"
                restorable="true"/>
    </extension>

    <!-- Editors — MemIf Module Manager. extensions="arxml" + default="true"
         意味着 Eclipse Project Explorer 双击任何 .arxml 文件都默认走我们
         这个 FormEditor。Project Explorer 输入是 IFile → IFileEditorInput，
         MemIfModuleManagerEditor.resolveFile 已经支持。 -->
    <extension
            point="org.eclipse.ui.editors">
        <editor
                id="cn.com.myorg.bswbuilder.ui.editors.MemIfModuleManagerEditor"
                name="MemIf Module Manager"
                extensions="arxml"
                class="cn.com.myorg.bswbuilder.ui.editors.MemIfModuleManagerEditor"
                default="true"
                contributorClass="org.eclipse.ui.part.EditorActionBarContributor"/>

        <!-- v0.2 起 CDT feature 接管 .c/.h 编辑器 (语法高亮 + folding +
             outline + include 跳转)。我们之前注册的 plain TextEditor
             已删 — CDT 注册的 C/C++ Editor 优先级更高，自动作为 default。 -->
    </extension>

    <!-- Commands — Validate / Generate / 其它 stub。从 Project Explorer
         右键菜单触发。 -->
    <extension
            point="org.eclipse.ui.commands">
        <category
                id="cn.com.myorg.bswbuilder.commands.category"
                name="BSW Builder"/>
        <command
                categoryId="cn.com.myorg.bswbuilder.commands.category"
                defaultHandler="cn.com.myorg.bswbuilder.ui.handlers.GenerateMemIfHandler"
                id="cn.com.myorg.bswbuilder.commands.generateMemIf"
                name="Generate"/>
        <command
                categoryId="cn.com.myorg.bswbuilder.commands.category"
                defaultHandler="cn.com.myorg.bswbuilder.ui.handlers.ValidateMemIfHandler"
                id="cn.com.myorg.bswbuilder.commands.validateMemIf"
                name="Validate"/>
        <command
                categoryId="cn.com.myorg.bswbuilder.commands.category"
                defaultHandler="cn.com.myorg.bswbuilder.ui.handlers.SynchronizeModuleStubHandler"
                id="cn.com.myorg.bswbuilder.commands.synchronizeModule"
                name="Synchronize Module"/>
        <command
                categoryId="cn.com.myorg.bswbuilder.commands.category"
                defaultHandler="cn.com.myorg.bswbuilder.ui.handlers.UpdateBswmdStubHandler"
                id="cn.com.myorg.bswbuilder.commands.updateBswmd"
                name="Update Bswmd"/>
        <command
                categoryId="cn.com.myorg.bswbuilder.commands.category"
                defaultHandler="cn.com.myorg.bswbuilder.ui.handlers.DeleteModuleStubHandler"
                id="cn.com.myorg.bswbuilder.commands.deleteModule"
                name="Delete"/>
    </extension>

    <!-- 右键菜单 — 挂到 Eclipse Project Explorer 的 popup 上。
         visibleWhen 限定: 选中的是 IFile + 扩展名 .arxml + 路径含
         /BSW_Builder/ (即 BSW 模块配置文件，不是 bswmds/ 下的描述文件)。
         5 项扁平结构跟参考 V25.10 一致 (用户 2026-04-29 验证):
            Synchronize Module / Validate / Generate / Update Bswmd / Delete -->
    <extension
            point="org.eclipse.ui.menus">
        <menuContribution
                locationURI="popup:org.eclipse.ui.popup.any?after=additions">
            <command
                    commandId="cn.com.myorg.bswbuilder.commands.synchronizeModule"
                    label="Synchronize Module"
                    style="push">
                <visibleWhen checkEnabled="false">
                    <iterate ifEmpty="false">
                        <adapt type="org.eclipse.core.resources.IFile">
                            <test
                                    property="org.eclipse.core.resources.name"
                                    value="*.arxml"/>
                            <test
                                    property="org.eclipse.core.resources.path"
                                    value="*/BSW_Builder/*"/>
                        </adapt>
                    </iterate>
                </visibleWhen>
            </command>
            <command
                    commandId="cn.com.myorg.bswbuilder.commands.validateMemIf"
                    label="Validate"
                    style="push">
                <visibleWhen checkEnabled="false">
                    <iterate ifEmpty="false">
                        <adapt type="org.eclipse.core.resources.IFile">
                            <test
                                    property="org.eclipse.core.resources.name"
                                    value="*.arxml"/>
                            <test
                                    property="org.eclipse.core.resources.path"
                                    value="*/BSW_Builder/*"/>
                        </adapt>
                    </iterate>
                </visibleWhen>
            </command>
            <command
                    commandId="cn.com.myorg.bswbuilder.commands.generateMemIf"
                    label="Generate"
                    style="push">
                <visibleWhen checkEnabled="false">
                    <iterate ifEmpty="false">
                        <adapt type="org.eclipse.core.resources.IFile">
                            <test
                                    property="org.eclipse.core.resources.name"
                                    value="*.arxml"/>
                            <test
                                    property="org.eclipse.core.resources.path"
                                    value="*/BSW_Builder/*"/>
                        </adapt>
                    </iterate>
                </visibleWhen>
            </command>
            <command
                    commandId="cn.com.myorg.bswbuilder.commands.updateBswmd"
                    label="Update Bswmd"
                    style="push">
                <visibleWhen checkEnabled="false">
                    <iterate ifEmpty="false">
                        <adapt type="org.eclipse.core.resources.IFile">
                            <test
                                    property="org.eclipse.core.resources.name"
                                    value="*.arxml"/>
                            <test
                                    property="org.eclipse.core.resources.path"
                                    value="*/BSW_Builder/*"/>
                        </adapt>
                    </iterate>
                </visibleWhen>
            </command>
            <command
                    commandId="cn.com.myorg.bswbuilder.commands.deleteModule"
                    label="Delete"
                    style="push">
                <visibleWhen checkEnabled="false">
                    <iterate ifEmpty="false">
                        <adapt type="org.eclipse.core.resources.IFile">
                            <test
                                    property="org.eclipse.core.resources.name"
                                    value="*.arxml"/>
                            <test
                                    property="org.eclipse.core.resources.path"
                                    value="*/BSW_Builder/*"/>
                        </adapt>
                    </iterate>
                </visibleWhen>
            </command>
        </menuContribution>
    </extension>

    <!-- AUTOSAR Explorer view — 自定义 CommonNavigator 子类。
         参考: cn.com.isoft.pal.ui.explorer.AutosarNavigator
              (view id cn.com.isoft.pal.views.autosarexplorer)。 -->
    <extension point="org.eclipse.ui.views">
        <category
                id="cn.com.myorg.bswbuilder.ui.viewCategory"
                name="BSW Builder"/>
        <view
                allowMultiple="false"
                category="cn.com.myorg.bswbuilder.ui.viewCategory"
                class="cn.com.myorg.bswbuilder.ui.navigator.BswAutosarExplorerView"
                id="cn.com.myorg.bswbuilder.ui.bswExplorer"
                name="AUTOSAR Explorer"
                restorable="true"/>
    </extension>

    <!-- navigatorContent — mal model 树 (BswBuilderModel/EcuConfig/ModuleKind/Module)。
         参考: cn.com.isoft.bswbuilder.ui plugin.xml (triggerPoints=BswBuilderModel)
              + cn.com.isoft.pal plugin.xml (CustomExplorerContentProvider 桥接 IProject->BswBuilderModel)。
         我们合并成单 provider：getChildren 处理 IWorkspaceRoot/IProject/4 个 mal model 类型。 -->
    <extension point="org.eclipse.ui.navigator.navigatorContent">
        <navigatorContent
                contentProvider="cn.com.myorg.bswbuilder.ui.navigator.BswExplorerContentProvider"
                labelProvider="cn.com.myorg.bswbuilder.ui.navigator.BswExplorerLabelProvider"
                id="cn.com.myorg.bswbuilder.ui.bswNavigatorContent"
                name="BSW Builder"
                priority="high"
                activeByDefault="true">
            <triggerPoints>
                <or>
                    <instanceof value="org.eclipse.core.resources.IWorkspaceRoot"/>
                    <instanceof value="org.eclipse.core.resources.IProject"/>
                    <instanceof value="cn.com.myorg.mal.model.BswBuilderModel"/>
                    <instanceof value="cn.com.myorg.mal.model.EcuConfigurationModel"/>
                    <instanceof value="cn.com.myorg.mal.model.ModuleKindModel"/>
                    <instanceof value="cn.com.myorg.mal.model.ModuleModel"/>
                </or>
            </triggerPoints>
            <possibleChildren>
                <or>
                    <instanceof value="org.eclipse.core.resources.IProject"/>
                    <instanceof value="cn.com.myorg.mal.model.BswBuilderModel"/>
                    <instanceof value="cn.com.myorg.mal.model.EcuConfigurationModel"/>
                    <instanceof value="cn.com.myorg.mal.model.ModuleKindModel"/>
                    <instanceof value="cn.com.myorg.mal.model.ModuleModel"/>
                </or>
            </possibleChildren>
        </navigatorContent>
    </extension>

    <extension point="org.eclipse.ui.navigator.viewer">
        <viewer viewerId="cn.com.myorg.bswbuilder.ui.bswExplorer"/>
        <viewerContentBinding viewerId="cn.com.myorg.bswbuilder.ui.bswExplorer">
            <includes>
                <contentExtension pattern="cn.com.myorg.bswbuilder.ui.bswNavigatorContent"/>
            </includes>
        </viewerContentBinding>
    </extension>

</plugin>
