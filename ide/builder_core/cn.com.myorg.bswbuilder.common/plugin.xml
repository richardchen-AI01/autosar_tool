<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

    <!-- IDE pivot (2026-04-30): 不再自己撸 Application / WorkbenchAdvisor /
         ActionBar / Perspective。改用 Eclipse IDE 自带的
         org.eclipse.ui.ide.workbench 应用——跟 reference iSoft V25.10
         同款基础壳 (File/Edit/Search/Project/Window/Help 标准菜单 +
         Project Explorer + Find/Search/Compare 全套)。 -->
    <extension
            id="product"
            point="org.eclipse.core.runtime.products">
        <product
                application="org.eclipse.ui.ide.workbench"
                name="BSW Configurator (autosar_tool)">
            <property name="appName"      value="BSW Configurator"/>
            <property name="windowImages" value=""/>
            <property name="preferredPerspectiveId"
                      value="cn.com.myorg.bswbuilder.common.perspective"/>
        </product>
    </extension>

    <!-- Custom perspective: 在 IDE workbench 上叠加我们的 4 区布局。
         IDE 默认 perspective 仍然可用 (Window → Perspective → Open)。 -->
    <extension
            point="org.eclipse.ui.perspectives">
        <perspective
                class="cn.com.myorg.bswbuilder.common.app.Perspective"
                id="cn.com.myorg.bswbuilder.common.perspective"
                name="BSW Configurator"/>
    </extension>

    <!-- Sphinx EditingDomain factory listener — 跟参考 iSoft V25.10
         (cn.com.isoft.pal.listeners.TransactionalEditingDomainFactoryListener)
         同款注册路径。注册之后 Sphinx 自动给 AUTOSAR metamodel 资源建
         TransactionalEditingDomain，否则 ModelDescriptor 操作走到
         TransactionUtil.runExclusive(null, …) 抛 NPE (Generate 后弹错框)。

         applicableFor 的 metamodelDescriptorIdPattern 跟 iSoft 一致，
         匹配 org.artop.aal.autosar40 / org.artop.aal.autosar448 等。 -->
    <extension
            point="org.eclipse.sphinx.emf.editingDomainFactoryListeners">
        <listener
                class="cn.com.myorg.bswbuilder.common.app.BswEditingDomainFactoryListener"
                id="cn.com.myorg.bswbuilder.common.editingDomainFactoryListener">
            <applicableFor
                    metaModelDescriptorIdPattern="org.artop.aal.autosar\d\d">
            </applicableFor>
        </listener>
    </extension>

    <!-- Project nature — 标记一个 Eclipse 项目是 BSW workspace。Sphinx 用
         project nature 决定该不该给项目加载 AUTOSAR metamodel + 建
         EditingDomain。参考 iSoft 注册 cn.com.isoft.workspace.bswbuildernature
         (cn.com.isoft.pal.workspace.natures.BSWBuilderNature) 同款路径，
         我们 ID 改成 cn.com.myorg.bswbuilder.common.bswBuilderNature 不撞名。 -->
    <extension
            id="bswBuilderNature"
            name="BSW Builder Nature"
            point="org.eclipse.core.resources.natures">
        <runtime>
            <run class="cn.com.myorg.bswbuilder.common.app.BswBuilderNature"/>
        </runtime>
    </extension>

    <!-- Module registration extension point.
         Mirrors iSoft V25.10's `cn.com.isoft.bswbuilder.extensionpoints.module`
         so per-module bundles (modules.memif, modules.det, modules.nvm, ...)
         each declare:
           shortName        — module ECUC short name, e.g. "MemIf"
           moduledefinition — bundle-relative path to the ECUC schema arxml
           bswmd            — bundle-relative path to a BSWMD skeleton (optional)
           kind             — coarse category, e.g. "MEM" / "COM" / "MCAL"
           vendor / version — for display + traceability
           imageIdentifier  — icon key for the tree view
           editor / generator / validator / moduleDescriptor / updateBswmd
                            — fully-qualified class names (optional until the
                              corresponding Java side lands; left as open
                              attributes for forward compatibility) -->
    <extension-point
            id="cn.com.myorg.bswbuilder.extensionpoints.module"
            name="BSW Builder Module"
            schema="schema/module.exsd"/>

</plugin>
