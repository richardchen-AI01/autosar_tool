<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<!--
  MemIf module registration. Mirrors the iSoft V25.10 contribution shape but
  drops attributes whose Java backing class hasn't been written yet
  (editor / generator / validator / moduleDescriptor / updateBswmd). Those
  stay open so M3.4+ can fill them in without renaming the extension point.

  shortName        — "MemIf"
  moduledefinition — bundle-relative arxml shipped next to plugin.xml
  kind             — "MEM" (memory abstraction)
  vendor / version — autosar_tool / 0.1.0
-->
<plugin>
   <extension
         point="cn.com.myorg.bswbuilder.extensionpoints.module">
      <module
            shortName="MemIf"
            moduledefinition="MemIfDef.arxml"
            kind="MEM"
            vendor="autosar_tool"
            version="0.1.0"
            imageIdentifier="MemIf"/>
   </extension>

   <!-- "Load MemIf ARXML" 顶部 toolbar 已删 (用户反馈 #3, 2026-04-29)。
        Phase 1 早期 smoke-test 用的快捷按钮，U2 起 ARXML 加载走
        "双击 Autosar Explorer 节点 → MemIfModuleManagerEditor.init()"
        正式路径，不需要顶栏按钮。LoadMemIfArxmlHandler 类保留代码可用，
        但不再通过 plugin.xml 注册成 UI 入口。 -->
</plugin>
