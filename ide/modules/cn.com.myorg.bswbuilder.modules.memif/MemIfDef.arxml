<?xml version='1.0' encoding='UTF-8'?>
<!--
  MemIf ECUC schema (own copy, M3.3 / v0.2 landing).

  Standard 3 params (DevErrorDetect / NumberOfDevices / VersionInfoApi) follow
  AUTOSAR R23-11 / 4.9.0 spec verbatim. The 4th param `MemIfModuleVersion` is
  a vendor probe kept for the docs §15 verification — `test_memif_full.sh`
  step 7 asserts it round-trips through generator into MemIf_Cfg.h.

  UUIDs are fresh (not iSoft's). Trace IDs (ECUC_MemIf_*) are AUTOSAR-public.
-->
<AUTOSAR xmlns="http://autosar.org/schema/r4.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://autosar.org/schema/r4.0 AUTOSAR_00052.xsd">
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>AUTOSAR</SHORT-NAME>
      <ELEMENTS>
        <ECUC-MODULE-DEF UUID="b1d4f0a0-1111-4a00-9000-000000000001">
          <SHORT-NAME>MemIf</SHORT-NAME>
          <DESC>
            <L-2 L="EN">Configuration of the MemIf (Memory Abstraction Interface) module.</L-2>
          </DESC>
          <ADMIN-DATA>
            <DOC-REVISIONS>
              <DOC-REVISION>
                <REVISION-LABEL>4.9.0</REVISION-LABEL>
                <ISSUED-BY>AUTOSAR</ISSUED-BY>
              </DOC-REVISION>
            </DOC-REVISIONS>
          </ADMIN-DATA>
          <RELATED-TRACE-ITEM-REF BASE="ArTrace" DEST="TRACEABLE">ECUC_MemIf_00025</RELATED-TRACE-ITEM-REF>
          <LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
          <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
          <POST-BUILD-VARIANT-SUPPORT>false</POST-BUILD-VARIANT-SUPPORT>
          <CONTAINERS>
            <ECUC-PARAM-CONF-CONTAINER-DEF UUID="b1d4f0a0-1111-4a00-9000-000000000002">
              <SHORT-NAME>MemIfGeneral</SHORT-NAME>
              <DESC>
                <L-2 L="EN">Configuration of the memory abstraction interface (Memif) module.</L-2>
              </DESC>
              <RELATED-TRACE-ITEM-REF BASE="ArTrace" DEST="TRACEABLE">ECUC_MemIf_00034</RELATED-TRACE-ITEM-REF>
              <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
              <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
              <ORIGIN>AUTOSAR_ECUC</ORIGIN>
              <PARAMETERS>
                <ECUC-BOOLEAN-PARAM-DEF UUID="b1d4f0a0-1111-4a00-9000-000000000003">
                  <SHORT-NAME>MemIfDevErrorDetect</SHORT-NAME>
                  <DESC>
                    <L-2 L="EN">Switches the development error detection and notification on or off.</L-2>
                  </DESC>
                  <INTRODUCTION>
                    <P>
                      <L-1 L="EN">* true: detection and notification is enabled. * false: detection and notification is disabled.</L-1>
                    </P>
                  </INTRODUCTION>
                  <RELATED-TRACE-ITEM-REF BASE="ArTrace" DEST="TRACEABLE">ECUC_MemIf_00035</RELATED-TRACE-ITEM-REF>
                  <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                  <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                  <SCOPE>LOCAL</SCOPE>
                  <ORIGIN>AUTOSAR_ECUC</ORIGIN>
                  <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                  <VALUE-CONFIG-CLASSES>
                    <ECUC-VALUE-CONFIGURATION-CLASS>
                      <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                      <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                    </ECUC-VALUE-CONFIGURATION-CLASS>
                  </VALUE-CONFIG-CLASSES>
                  <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                  <DEFAULT-VALUE>false</DEFAULT-VALUE>
                </ECUC-BOOLEAN-PARAM-DEF>
                <ECUC-INTEGER-PARAM-DEF UUID="b1d4f0a0-1111-4a00-9000-000000000004">
                  <SHORT-NAME>MemIfNumberOfDevices</SHORT-NAME>
                  <DESC>
                    <L-2 L="EN">Concrete number of underlying memory abstraction modules.</L-2>
                  </DESC>
                  <INTRODUCTION>
                    <P>
                      <L-1 L="EN">Calculation Formula: Count number of configured EA and FEE modules.</L-1>
                    </P>
                  </INTRODUCTION>
                  <RELATED-TRACE-ITEM-REF BASE="ArTrace" DEST="TRACEABLE">ECUC_MemIf_00033</RELATED-TRACE-ITEM-REF>
                  <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                  <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                  <SCOPE>LOCAL</SCOPE>
                  <ORIGIN>AUTOSAR_ECUC</ORIGIN>
                  <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                  <VALUE-CONFIG-CLASSES>
                    <ECUC-VALUE-CONFIGURATION-CLASS>
                      <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                      <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                    </ECUC-VALUE-CONFIGURATION-CLASS>
                  </VALUE-CONFIG-CLASSES>
                  <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                  <MAX>2</MAX>
                  <MIN>1</MIN>
                </ECUC-INTEGER-PARAM-DEF>
                <ECUC-BOOLEAN-PARAM-DEF UUID="b1d4f0a0-1111-4a00-9000-000000000005">
                  <SHORT-NAME>MemIfVersionInfoApi</SHORT-NAME>
                  <DESC>
                    <L-2 L="EN">Pre-processor switch to enable / disable the API to read out the modules version information.</L-2>
                  </DESC>
                  <INTRODUCTION>
                    <P>
                      <L-1 L="EN">true: Version info API enabled. false: Version info API disabled.</L-1>
                    </P>
                  </INTRODUCTION>
                  <RELATED-TRACE-ITEM-REF BASE="ArTrace" DEST="TRACEABLE">ECUC_MemIf_00032</RELATED-TRACE-ITEM-REF>
                  <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                  <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                  <SCOPE>LOCAL</SCOPE>
                  <ORIGIN>AUTOSAR_ECUC</ORIGIN>
                  <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                  <VALUE-CONFIG-CLASSES>
                    <ECUC-VALUE-CONFIGURATION-CLASS>
                      <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                      <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                    </ECUC-VALUE-CONFIGURATION-CLASS>
                  </VALUE-CONFIG-CLASSES>
                  <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                  <DEFAULT-VALUE>false</DEFAULT-VALUE>
                </ECUC-BOOLEAN-PARAM-DEF>
                <ECUC-STRING-PARAM-DEF UUID="b1d4f0a0-1111-4a00-9000-000000000006">
                  <SHORT-NAME>MemIfModuleVersion</SHORT-NAME>
                  <DESC>
                    <L-2 L="EN">PROBE PARAMETER: experimental string to verify whether jar's MemIfDef.arxml drives the IDE form and whether the value reaches generated code.</L-2>
                  </DESC>
                  <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                  <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                  <SCOPE>LOCAL</SCOPE>
                  <ORIGIN>VENDOR</ORIGIN>
                  <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                  <VALUE-CONFIG-CLASSES>
                    <ECUC-VALUE-CONFIGURATION-CLASS>
                      <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                      <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                    </ECUC-VALUE-CONFIGURATION-CLASS>
                  </VALUE-CONFIG-CLASSES>
                  <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                  <DEFAULT-VALUE>TEST_PROBE_42_V25_10</DEFAULT-VALUE>
                </ECUC-STRING-PARAM-DEF>
              </PARAMETERS>
            </ECUC-PARAM-CONF-CONTAINER-DEF>
          </CONTAINERS>
          <SUPPORTED-CONFIG-VARIANTS>
            <SUPPORTED-CONFIG-VARIANT>VARIANT-PRE-COMPILE</SUPPORTED-CONFIG-VARIANT>
          </SUPPORTED-CONFIG-VARIANTS>
        </ECUC-MODULE-DEF>
      </ELEMENTS>
    </AR-PACKAGE>
  </AR-PACKAGES>
</AUTOSAR>
