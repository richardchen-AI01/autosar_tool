                    </BSW-TIMING-EVENT>
                  </EVENTS>
                  <DISTINGUISHED-PARTITIONS>
                    <BSW-DISTINGUISHED-PARTITION>
                      <SHORT-NAME>Fee_EcucPartition</SHORT-NAME>
                    </BSW-DISTINGUISHED-PARTITION>
                  </DISTINGUISHED-PARTITIONS>
